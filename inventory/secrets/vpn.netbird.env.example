# Beispielwerte fuer NetBird. Kopieren nach vpn.netbird.env, ausfuellen,
# dann verschluesseln (analog zu vpn.tailscale.env.example).
#
# NB_MANAGEMENT_URL leer => SaaS api.netbird.io
# NB_MANAGEMENT_URL gesetzt => self-hosted, z.B. https://nb.example.com

NB_SETUP_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
NB_MANAGEMENT_URL=
NB_HOSTNAME=inventory-vps
