# authgate — Secrets fuer das Auth-Sidecar.  KEINE echten Werte committen.
#
# Einrichtung:
#   1. Kopieren:   cp authgate.env.example authgate.env
#   2. Secret:     docker compose run --rm authgate gensecret
#                  -> Wert nach AUTHGATE_SESSION_SECRET
#   3. Benutzer:   docker compose run --rm -e AUTHGATE_PW=<pw> authgate hashpw <name>
#                  -> ausgegebene Zeile nach AUTHGATE_USERS
#
# Produktiv: diese Datei mit sops verschluesseln (authgate.env.enc, wird
# committet) und vor `docker compose up` nach ./secrets/authgate.env
# entschluesseln — analog zum vpn.<provider>.env-Muster.

# HMAC-Schluessel fuer Session-Cookies. Pflicht, >= 32 Byte zufaellig.
# Ohne diesen Wert erzeugt authgate ein ephemeres Secret -> Sessions
# ueberleben keinen Neustart.
AUTHGATE_SESSION_SECRET=CHANGE_ME

# Benutzer als `name=rounds$salthex$hashhex`, mehrere mit ';' getrennt.
# Datensaetze erzeugt `authgate hashpw <name>`.
AUTHGATE_USERS=CHANGE_ME
