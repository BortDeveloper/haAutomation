# Beispielwerte fuer Tailscale. Kopieren nach vpn.tailscale.env, ausfuellen,
# dann verschluesseln:
#   sops -e --age $(cat strato.age.pub) vpn.tailscale.env > vpn.tailscale.env.enc
#   rm vpn.tailscale.env
#
# Die unverschluesselte Variante NIE committen — siehe .gitignore.

TS_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXXX
TS_HOSTNAME=inventory-strato
